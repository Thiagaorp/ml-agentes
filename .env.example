# Credenciais da sua aplicacao no DevCenter do Mercado Livre
# https://developers.mercadolivre.com.br/devcenter
ML_CLIENT_ID=
ML_CLIENT_SECRET=
# Tem que ser EXATAMENTE a redirect URI cadastrada na aplicacao
ML_REDIRECT_URI=

# Chave da API do Claude (console.anthropic.com)
ANTHROPIC_API_KEY=

# Modelo padrao (fallback se nao definir por agente)
ANTHROPIC_MODEL=claude-sonnet-4-6
# Modelo por agente (ja vem com bom default; descomente para trocar):
#  Haiku = barato/rapido (roda em loop) | Sonnet = mais qualidade de texto
# MODELO_ANALISTA=claude-haiku-4-5-20251001
# MODELO_DETECTOR=claude-haiku-4-5-20251001
# MODELO_PALAVRAS=claude-sonnet-4-6
# MODELO_CRIADOR=claude-sonnet-4-6

# Site do Mercado Livre (MLB = Brasil)
ML_SITE=MLB
